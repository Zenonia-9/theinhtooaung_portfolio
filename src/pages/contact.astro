---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import BrandIcon from "../components/ui/BrandIcon.astro";

const contactCards = [
  {
    title: "Email",
    value: "theinhtooaung906@gmail.com",
    href: "mailto:theinhtooaung906@gmail.com",
    icon: "mail",
  },
  {
    title: "GitHub",
    value: "github.com/Zenonia-9",
    href: "https://github.com/Zenonia-9",
    icon: "github",
  },
  {
    title: "LinkedIn",
    value: "linkedin.com/in/thein-htoo-aung",
    href: "https://www.linkedin.com/in/thein-htoo-aung/",
    icon: "linkedin",
  },
  {
    title: "Telegram",
    value: "@NoctivagusAeternus",
    href: "https://t.me/NoctivagusAeternus",
    icon: "telegram",
  },
  {
    title: "Discord",
    value: "theinhtooaung",
    href: "https://discord.com/users/1152421433528561734",
    icon: "discord",
  },
  {
    title: "Phone",
    value: "+95 9794628265",
    href: "tel:+959794628265",
    icon: "phone",
  },
  {
    title: "Location / Timezone",
    value: "Yangon, Myanmar · MMT (UTC+6:30)",
    href: null,
    icon: "globe",
  },
  {
    title: "Download CV",
    value: "Thein-Htoo-Aung-CV.pdf",
    href: "/Thein-Htoo-Aung-CV.pdf",
    icon: "file-text",
  },
];
---

<BaseLayout title="Contact | Thein Htoo Aung">
  <section class="py-10 sm:py-14">
    <SectionTitle
      description="Open for freelance collaboration, Odoo module work, backend-heavy business software, localization, reports, and workflow automation."
      eyebrow="Contact"
      title="Project discussion and availability"
    />

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {contactCards.map((card) => {
        const cardContent = (
          <>
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-primary/30 bg-primary-soft font-mono text-sm font-semibold tracking-[0.2em] text-primary">
              {["discord", "github", "linkedin", "telegram", "phone", "mail", "globe", "file-text"].includes(card.icon) ? (
                <BrandIcon name={card.icon} />
              ) : (
                card.icon
              )}
            </div>
            <div class="mt-10">
              <p class="font-mono text-xs uppercase tracking-[0.24em] text-muted">
                {card.title}
              </p>
              <p class="mt-3 break-words text-lg font-semibold tracking-[-0.02em] text-text">
                {card.value}
              </p>
            </div>
          </>
        );

        return card.href ? (
          <a
            class="surface-card group flex min-h-52 flex-col justify-between p-6 hover:border-secondary/40"
            href={card.href}
            rel={card.href.startsWith("http") ? "noreferrer" : undefined}
            target={card.href.startsWith("http") ? "_blank" : undefined}
          >
            {cardContent}
          </a>
        ) : (
          <div class="surface-card flex min-h-52 flex-col justify-between p-6">
            {cardContent}
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
