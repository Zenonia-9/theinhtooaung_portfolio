---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ServerCog, Code2, Wrench } from "lucide-react";

const getLevel = (proficiency) => {
  if (proficiency >= 90) return "Expert";
  if (proficiency >= 80) return "Advanced";
  if (proficiency >= 70) return "Strong";
  if (proficiency >= 60) return "Good";
  if (proficiency >= 40) return "Working";
  return "Learning";
};

const skillGroups = [
  {
    title: "Backend",
    Icon: ServerCog,
    skills: [
      { name: "Odoo", proficiency: 78 },
      { name: "Python", proficiency: 90 },
      { name: "PostgreSQL", proficiency: 80 },
      { name: "SQL", proficiency: 80 },
      { name: "XML", proficiency: 80 },
      { name: "QWeb", proficiency: 85 },
      { name: "Docker", proficiency: 76 },
      { name: "Linux", proficiency: 76 },
      { name: "Git", proficiency: 70 },
    ],
  },
  {
    title: "Frontend",
    Icon: Code2,
    skills: [
      { name: "HTML", proficiency: 79 },
      { name: "CSS", proficiency: 71 },
      { name: "JavaScript", proficiency: 67 },
      { name: "Astro", proficiency: 60 },
      { name: "React", proficiency: 60 },
    ],
  },
  {
    title: "Tools / Other",
    Icon: Wrench,
    skills: [
      { name: "Odoo Studio", proficiency: 80 },
      { name: "Reporting", proficiency: 83 },
      { name: "UI Design", proficiency: 58 },
      { name: "Figma", proficiency: 20 },
    ],
  },
];
---

<BaseLayout title="Skills | Thein Htoo Aung">
  <section class="section-shell">
    <div class="max-w-3xl">
      <p class="font-mono text-sm uppercase tracking-[0.28em] text-secondary">
        Skills
      </p>

      <h1 class="mt-4 font-display text-4xl font-bold tracking-[-0.04em] text-text sm:text-6xl">
        Backend depth with ERP workflow focus.
      </h1>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {skillGroups.map(({ title, Icon, skills }) => (
        <article class="surface-card neon-panel p-7">
          <div class="flex items-center gap-4">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary-soft text-primary">
              <Icon className="h-6 w-6" aria-hidden="true" />
            </span>

            <h2 class="font-display text-2xl font-bold text-text">
              {title}
            </h2>
          </div>

          <div class="mt-7 space-y-4">
            {skills.map((skill) => {
              const level = getLevel(skill.proficiency);

              return (
                <div class="rounded-[18px] border border-border bg-bg/55 p-4">
                  <div class="flex items-center justify-between gap-4">
                    <span class="font-semibold text-text">
                      {skill.name}
                    </span>

                    <span class="text-xs font-semibold uppercase tracking-[0.16em] text-secondary">
                      {level}
                    </span>
                  </div>

                  <div class="mt-3 h-2 overflow-hidden rounded-full bg-border/60">
                    <div
                      class="h-full rounded-full bg-primary shadow-[0_0_18px_rgba(190,103,255,0.55)] transition-all duration-700 ease-out"
                      style={`width: ${skill.proficiency}%`}
                      aria-label={`${skill.name} proficiency ${skill.proficiency}%`}
                    />
                  </div>

                  <div class="mt-2 flex justify-end">
                    <span class="font-mono text-xs text-muted">
                      {skill.proficiency}%
                    </span>
                  </div>
                </div>
              );
            })}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
