---
import BaseLayout from "../layouts/BaseLayout.astro";

const experience = [
  {
    from: "Feb 2026",
    to: "Present",
    role: "Junior Odoo Developer",
    company: "ARI Co., Ltd",
    description:
      "Develop custom Odoo modules and backend business workflows with emphasis on accounting, localization, reporting, and operational automation. Deliver QWeb PDF reports, accounting report customization, workflow extensions, and maintainable ERP solutions for production use.",
    highlights: [
      "Built Myanmar Address Localization module suite",
      "Designed Consignment Sale workflow system",
      "Customized accounting reports and QWeb PDF prints",
      "Implemented backend-focused business workflow automation",
    ],
    stack: ["Odoo", "Python", "PostgreSQL", "Docker", "QWeb", "XML"],
  },
  {
    from: "Mar 2023",
    to: "Present",
    role: "Self-Taught Software Developer",
    company: "Independent Learning & Personal Projects",
    description:
      "Started software development through self-directed learning across Python, PHP, databases, and web technologies. Built practical projects including a posting website with PHP and MySQL, explored Unity game development with C#, and gradually shifted toward backend engineering and ERP development.",
    highlights: [
      "Focused mainly on Python and backend fundamentals",
      "Built a PHP and MySQL posting website",
      "Learned Java fundamentals and introductory OOP concepts",
      "Explored beginner Unity game development with C#",
    ],
    stack: ["Python", "PHP", "MySQL", "HTML", "CSS", "JavaScript", "Unity", "C#"],
  },
];
---

<BaseLayout title="Experience | Thein Htoo Aung">
  <section class="section-shell">
    <p class="font-mono text-sm uppercase tracking-[0.28em] text-secondary">
      Experience Timeline
    </p>

    <h1 class="mt-4 font-display text-4xl font-bold tracking-[-0.04em] text-text sm:text-6xl">
      Backend growth through real ERP work.
    </h1>

    <div class="mt-12 space-y-5">
      {experience.map((item) => (
        <article class="surface-card grid gap-6 p-6 md:grid-cols-[180px_1fr]">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted">
              From
            </p>

            <p class="mt-1 font-display text-2xl font-bold text-primary">
              {item.from}
            </p>

            <div class="my-4 h-px w-16 bg-border md:h-12 md:w-px"></div>

            <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted">
              To
            </p>

            <p class="mt-1 font-display text-2xl font-bold text-primary">
              {item.to}
            </p>
          </div>

          <div>
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <h2 class="font-display text-2xl font-bold text-text">
                {item.role}
              </h2>

              <span class="text-sm text-muted">
                {item.company}
              </span>
            </div>

            <p class="mt-3 text-sm leading-7 text-muted">
              {item.description}
            </p>

            <ul class="mt-4 space-y-2">
              {item.highlights.map((highlight) => (
                <li class="flex gap-3 text-sm leading-6 text-muted">
                  <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-primary" />
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>

            <div class="mt-4 flex flex-wrap gap-2">
              {item.stack.map((tag) => (
                <span class="rounded-full border border-border bg-bg/50 px-3 py-1 text-xs text-muted">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
