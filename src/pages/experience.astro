---
import BaseLayout from "../layouts/BaseLayout.astro";

const experience = [
  {
    from: "Feb 2026",
    to: "Present",
    role: "Junior Odoo Developer",
    company: "ARI Co., Ltd",
    description:
      "Developing and customizing Odoo modules, improving business workflows, building reports, and supporting backend features with Python, PostgreSQL, and Docker-based development environments.",
    stack: ["Odoo", "Python", "PostgreSQL", "Docker"],
  },
  {
    from: "Mar 2023",
    to: "Present",
    role: "Self-Taught Software Developer",
    company: "Independent Learning & Personal Projects",
    description:
      "Studied programming through hands-on projects, mainly with Python. Explored Java fundamentals, built medium-level PHP web projects including a Facebook-style posting website, and created beginner Unity games using C#.",
    stack: ["Python", "PHP", "Java", "C#", "Unity", "Web Development"],
  },
];
---

<BaseLayout title="Experience | Thein Htoo Aung">
  <section class="section-shell">
    <p class="font-mono text-sm uppercase tracking-[0.28em] text-secondary">
      Experience Timeline
    </p>

    <h1 class="mt-4 font-display text-4xl font-bold tracking-[-0.04em] text-text sm:text-6xl">
      Work history, ready for exact details.
    </h1>

    <div class="mt-12 space-y-5">
      {experience.map((item) => (
        <article class="surface-card grid gap-6 p-6 md:grid-cols-[180px_1fr]">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted">
              From
            </p>

            <p class="mt-1 font-display text-2xl font-bold text-primary">
              {item.from}
            </p>

            <div class="my-4 h-px w-16 bg-border md:h-12 md:w-px"></div>

            <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted">
              To
            </p>

            <p class="mt-1 font-display text-2xl font-bold text-primary">
              {item.to}
            </p>
          </div>

          <div>
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <h2 class="font-display text-2xl font-bold text-text">
                {item.role}
              </h2>

              <span class="text-sm text-muted">
                {item.company}
              </span>
            </div>

            <p class="mt-3 text-sm leading-7 text-muted">
              {item.description}
            </p>

            <div class="mt-4 flex flex-wrap gap-2">
              {item.stack.map((tag) => (
                <span class="rounded-full border border-border bg-bg/50 px-3 py-1 text-xs text-muted">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>