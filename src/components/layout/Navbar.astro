---
import ThemeToggle from "./ThemeToggle.jsx";
import MobileMenu from "./MobileMenu.jsx";

const pathname = Astro.url.pathname;
const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/skills", label: "Skills" },
  { href: "/projects", label: "Projects" },
  { href: "/experience", label: "Experience" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-40 border-b border-border/70 bg-bg-elevated/82 backdrop-blur-xl">
  <div class="mx-auto flex max-w-[1400px] items-center justify-between gap-6 px-4 py-4 sm:px-6 lg:px-8">
    <a class="group inline-flex items-center gap-3" href="/">
      <span class="inline-flex h-12 w-12 items-center justify-center overflow-hidden rounded-[18px] border border-primary/30 bg-card p-2 shadow-soft transition-transform duration-200 group-hover:-translate-y-0.5">
        <img
          src="/favicon.svg"
          alt="Thein Htoo Aung logo"
          class="h-full w-full object-contain"
        />
      </span>
      <span>
        <span class="block font-display text-base font-bold tracking-[-0.03em] text-text">
          Thein Htoo Aung
        </span>
        <span class="block text-sm text-muted">Odoo and system builder</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 rounded-full border border-border bg-card/65 p-1.5 shadow-soft lg:flex">
      {links.map((link) => {
        const active =
          link.href === "/" ? pathname === "/" : pathname.startsWith(link.href);
        return (
          <a
            class:list={[
              "relative rounded-full px-3 py-2.5 text-sm font-medium xl:px-4",
              active
                ? "bg-primary-soft text-primary"
                : "text-muted hover:text-text",
            ]}
            href={link.href}
          >
            {link.label}
            <span
              class:list={[
                "absolute inset-x-4 bottom-1 h-px bg-secondary transition-opacity",
                active ? "opacity-100" : "opacity-0 hover:opacity-100",
              ]}
            />
          </a>
        );
      })}
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <ThemeToggle client:load />
    </div>

    <MobileMenu client:load links={links} pathname={pathname} />
  </div>
</header>
