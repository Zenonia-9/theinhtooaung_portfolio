---
const socialLinks = [
  { href: "https://github.com/theinhtooaung", label: "GitHub" },
  { href: "https://www.linkedin.com/in/thein-htoo-aung/", label: "LinkedIn" },
  { href: "https://discord.com/users/1152421433528561734", label: "Discord" },
];
---

<footer class="border-t border-border/70 bg-bg-elevated/92">
  <div class="mx-auto grid max-w-[1400px] gap-8 px-4 py-12 sm:px-6 lg:grid-cols-[1.4fr_1fr] lg:px-8">
    <div>
      <div class="mb-5 h-1 w-20 rounded-full bg-secondary"></div>
      <h2 class="font-display text-2xl font-bold tracking-[-0.04em] text-text">
        Thein Htoo Aung
      </h2>
      <p class="mt-3 max-w-xl text-base leading-8 text-muted">
        Odoo developer, Python backend builder, and creative technologist focused on
        reliable business software with clear operational flows.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.26em] text-primary">Site</p>
        <div class="mt-4 flex flex-col gap-3">
          <a class="text-sm text-muted hover:text-primary" href="/">Home</a>
          <a class="text-sm text-muted hover:text-primary" href="/about">About</a>
          <a class="text-sm text-muted hover:text-primary" href="/skills">Skills</a>
          <a class="text-sm text-muted hover:text-primary" href="/projects">Projects</a>
          <a class="text-sm text-muted hover:text-primary" href="/experience">Experience</a>
          <a class="text-sm text-muted hover:text-primary" href="/contact">Contact</a>
        </div>
      </div>
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.26em] text-primary">Elsewhere</p>
        <div class="mt-4 flex flex-col gap-3">
          {socialLinks.map((link) => (
            <a
              class="text-sm text-muted hover:text-primary"
              href={link.href}
              rel="noreferrer"
              target="_blank"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- 
    IMPORTANT: This attribution section must remain intact if others use this design.
    It provides proper credit to the original creator and links back to their site.
  -->
  <div class="border-t border-border/70">
    <div class="mx-auto flex max-w-[1400px] flex-col gap-4 px-4 py-6 text-sm text-muted sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <div>
        <p>&copy; 2026 Thein Htoo Aung.</p>
        <p class="mt-1 text-xs opacity-80">Built with Astro.</p>
      </div>
      
      <div class="mt-4 sm:mt-0">
        <div class="rounded-lg border border-primary/20 bg-primary/5 p-4">
          <p class="font-medium text-primary">
            <span class="font-mono text-xs uppercase tracking-wider">Design Credit</span>
          </p>
          <p class="mt-1 text-sm">
            This portfolio design is based on the original work of 
            <a 
              href="https://theinhtooaung.vercel.app/" 
              class="font-semibold text-primary hover:underline"
              rel="noreferrer"
              target="_blank"
            >
              Thein Htoo Aung
            </a>.
          </p>
          <p class="mt-1 text-xs opacity-80">
            Please maintain this attribution if you use this design.
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>
