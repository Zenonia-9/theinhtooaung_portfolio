---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
const alignClass = align === "center" ? "mx-auto max-w-3xl text-center" : "max-w-3xl";
---

<div class={alignClass}>
  {eyebrow && (
    <p class="mb-4 font-mono text-sm uppercase tracking-[0.28em] text-primary">
      {eyebrow}
    </p>
  )}
  <h2 class="font-display text-3xl font-bold tracking-[-0.04em] text-text sm:text-4xl lg:text-5xl">
    {title}
  </h2>
  {description && (
    <p class="mt-4 text-base leading-8 text-muted sm:text-lg">{description}</p>
  )}
</div>
