---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  external?: boolean;
}

const { href, label, variant = "primary", external = false } = Astro.props;

const variantClass = {
  primary:
    "border-primary bg-primary text-black shadow-[0_0_0_1px_rgba(34,197,94,0.18),0_18px_48px_rgba(34,197,94,0.18)] hover:-translate-y-0.5 hover:bg-primary-hover",
  secondary:
    "border-border bg-card/80 text-text hover:border-secondary/45 hover:text-secondary",
}[variant];
---

<a
  class:list={[
    "inline-flex items-center justify-center gap-2 rounded-2xl border px-5 py-3 text-sm font-semibold tracking-[0.01em]",
    variantClass,
  ]}
  href={href}
  rel={external ? "noreferrer" : undefined}
  target={external ? "_blank" : undefined}
>
  {label}
</a>
